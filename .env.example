## RecycleRight Pakistan — local development env
## Copy to `.env` at repo root.
##
## Required by `lib/db` (PostgreSQL connection string)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/recycleright"
##
## Required by `artifacts/api-server` (Express server port)
PORT=8080
##
## Required by `artifacts/api-server` (JWT signing secret; keep this private)
## Generate a strong value, e.g.:
##   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_me_with_a_random_64+_char_secret"


## RecycleRight Pakistan — local development env
## Copy to `.env` at repo root.
##
## Required by `lib/db` (PostgreSQL connection string)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/recycleright"
##
## Required by `artifacts/api-server` (Express server port)
PORT=8080
##
## Required by `artifacts/api-server` (JWT signing secret; keep this private)
## Generate a strong value, e.g.:
##   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_me_with_a_random_64+_char_secret"

## Google Routes API key (used by /api/maps/route proxy)
GOOGLE_MAPS_API_KEY=""

## FCM via Firebase Admin SDK (used for push notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

## Points-to-PKR conversion for top-up redemption
REDEMPTION_POINTS_PER_PKR=10

## Top-up provider integration
## TOPUP_PROVIDER_MODE=mock | http
TOPUP_PROVIDER_MODE="mock"
TOPUP_PROVIDER_BASE_URL=""
TOPUP_PROVIDER_API_KEY=""

